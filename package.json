{
  "name": "spp-frontend",
  "private": true,
  "type": "module",
  "engineStrict": true,
  "engines": {
    "node": ">=22.x",
    "pnpm": ">=10.27.0"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prepare": "[ -f .husky/install.mjs ] && node .husky/install.mjs || true",
    "lint": "eslint .",
    "typecheck": "nuxt typecheck",
    "docker:build": "docker build -t spp-frontend:latest --target production .",
    "docker:prod": "docker compose up"
  },
  "dependencies": {
    "@iconify-json/simple-icons": "^1.2.65",
    "@nuxt/hints": "1.0.0-alpha.5",
    "@nuxt/image": "2.0.0",
    "@nuxt/scripts": "0.13.2",
    "@nuxt/test-utils": "3.22.0",
    "@nuxt/ui": "^4.3.0",
    "@nuxtjs/i18n": "^10.2.1",
    "@unhead/vue": "^2.1.1",
    "@unovis/ts": "^1.6.2",
    "@unovis/vue": "^1.6.2",
    "@vueuse/nuxt": "^14.1.0",
    "better-auth": "^1.4.10",
    "date-fns": "^4.1.0",
    "nuxt": "^4.2.2",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.0",
    "@commitlint/config-conventional": "^20.3.0",
    "@iconify-json/lucide": "^1.2.82",
    "@nuxt/eslint": "^1.12.1",
    "baseline-browser-mapping": "^2.9.11",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.2"
  },
  "packageManager": "pnpm@10.27.0"
}