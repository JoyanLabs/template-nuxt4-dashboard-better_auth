{
  "extends": [
    "github>nuxt/renovate-config-nuxt"
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "postUpdateOptions": [
    "pnpmDedupe"
  ],
  "packageRules": [
    {
      "matchDepTypes": [
        "resolutions"
      ],
      "enabled": false
    },
    {
      "matchPackageNames": [
        "pnpm"
      ],
      "enabled": false
    }
  ],
  "constraints": {
    "pnpm": "10.27.0"
  }
}