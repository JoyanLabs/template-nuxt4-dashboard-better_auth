ail","password","name"]},"BanUserDto":{"type":"object","properties":{"banReason":{"type":"string","description":"Razón del baneo","example":"Violación de términos de servicio"},"banExpiresIn":{"type":"number","description":"Duración del baneo en segundos","example":86400}}},"UpdateUserDto":{"type":"object","properties":{"name":{"type":"string","description":"Nuevo nombre del usuario","example":"Jane Doe"},"email":{"type":"string","description":"Nuevo email del usuario","example":"jane@example.com"}}},"SetPasswordDto":{"type":"object","properties":{"password":{"type":"string","description":"Nueva contraseña para el usuario","example":"NewSecurePass123!","minLength":8}},"required":["password"]},"UpdateRoleDto":{"type":"object","properties":{"role":{"type":"string","description":"Nuevo rol para el usuario","enum":["user","admin"],"example":"admin"}},"required":["role"]}}}}